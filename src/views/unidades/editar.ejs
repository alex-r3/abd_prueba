<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Unidad</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/styles.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid px-4">
            <a class="navbar-brand" href="/"><i class="fas fa-bus me-2"></i>Sistema de Pasajes</a>
        </div>
    </nav>

    <div class="container mt-5 mb-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="form-card">
                    <h1><i class="fas fa-edit me-3"></i>Editar Unidad</h1>
                    
                    <form action="/unidades/actualizar/<%= unidad.ID_UNIDAD %>" method="POST">
                        <div class="form-group">
                            <label for="numero_disco" class="form-label"><i class="fas fa-barcode me-2"></i>Número Disco</label>
                            <input type="text" class="form-control" id="numero_disco" name="numero_disco" value="<%= unidad.NUMERO_DISCO %>" required>
                        </div>
                        
                        <div class="form-group">
                            <label for="placa" class="form-label"><i class="fas fa-license-plate me-2"></i>Placa</label>
                            <input type="text" class="form-control" id="placa" name="placa" value="<%= unidad.PLACA %>" required>
                        </div>
                        
                        <div class="form-group">
                            <label for="capacidad" class="form-label"><i class="fas fa-users me-2"></i>Capacidad</label>
                            <input type="number" class="form-control" id="capacidad" name="capacidad" min="1" value="<%= unidad.CAPACIDAD %>" required>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-save me-2"></i>Actualizar Unidad
                            </button>
                            <a href="/unidades" class="btn btn-secondary btn-lg">
                                <i class="fas fa-times me-2"></i>Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

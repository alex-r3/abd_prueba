<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Pasaje</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/styles.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid px-4">
            <a class="navbar-brand" href="/"><i class="fas fa-bus me-2"></i>Sistema de Pasajes</a>
        </div>
    </nav>

    <div class="container mt-5 mb-5">
        <div class="row justify-content-center">
            <div class="col-md-7">
                <div class="form-card">
                    <h1><i class="fas fa-edit me-3"></i>Editar Pasaje</h1>
                    
                    <form action="/pasajes/actualizar/<%= pasaje.ID_PASAJE %>" method="POST">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="id_ruta" class="form-label"><i class="fas fa-map-marker-alt me-2"></i>Ruta</label>
                                    <select class="form-select" id="id_ruta" name="id_ruta" required>
                                        <% rutas.forEach(ruta => { %>
                                            <option value="<%= ruta.ID_RUTA %>" <%= pasaje.ID_RUTA == ruta.ID_RUTA ? 'selected' : '' %>>
                                                <%= ruta.NOMBRE_RUTA %> (<%= ruta.ORIGEN %> - <%= ruta.DESTINO %>)
                                            </option>
                                        <% }); %>
                                    </select>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="id_unidad" class="form-label"><i class="fas fa-bus me-2"></i>Unidad</label>
                                    <select class="form-select" id="id_unidad" name="id_unidad" required>
                                        <% unidades.forEach(unidad => { %>
                                            <option value="<%= unidad.ID_UNIDAD %>" <%= pasaje.ID_UNIDAD == unidad.ID_UNIDAD ? 'selected' : '' %>>
                                                <%= unidad.PLACA %> (Cap: <%= unidad.CAPACIDAD %>)
                                            </option>
                                        <% }); %>
                                    </select>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="id_tipo" class="form-label"><i class="fas fa-ticket-alt me-2"></i>Tipo de Pasaje</label>
                                    <select class="form-select" id="id_tipo" name="id_tipo" required>
                                        <% tipos.forEach(tipo => { %>
                                            <option value="<%= tipo.ID_TIPO %>" <%= pasaje.ID_TIPO == tipo.ID_TIPO ? 'selected' : '' %>>
                                                <%= tipo.DESCRIPCION %> ($<%= tipo.PRECIO_BASE %>)
                                            </option>
                                        <% }); %>
                                    </select>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="valor_final" class="form-label"><i class="fas fa-dollar-sign me-2"></i>Valor Final</label>
                                    <input type="number" class="form-control" id="valor_final" name="valor_final" step="0.01" min="0" value="<%= pasaje.VALOR_FINAL %>" required>
                                </div>
                            </div>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-save me-2"></i>Actualizar Pasaje
                            </button>
                            <a href="/pasajes" class="btn btn-secondary btn-lg">
                                <i class="fas fa-times me-2"></i>Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

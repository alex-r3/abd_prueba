<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pasajes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/styles.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid px-4">
            <a class="navbar-brand" href="/"><i class="fas fa-bus me-2"></i>Sistema de Pasajes</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/rutas"><i class="fas fa-map-marker-alt me-1"></i>Rutas</a></li>
                    <li class="nav-item"><a class="nav-link" href="/unidades"><i class="fas fa-truck me-1"></i>Unidades</a></li>
                    <li class="nav-item"><a class="nav-link" href="/tipos-pasaje"><i class="fas fa-ticket-alt me-1"></i>Tipos</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/pasajes"><i class="fas fa-receipt me-1"></i>Pasajes</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-5 mb-5">
        <div class="page-header d-flex justify-content-between align-items-center">
            <div>
                <h1><i class="fas fa-receipt me-3"></i>Gestión de Pasajes</h1>
            </div>
            <div>
                <a href="/pasajes/crear" class="btn btn-primary btn-lg me-2">
                    <i class="fas fa-plus me-2"></i>Nuevo Pasaje
                </a>
                <a href="/pasajes/filtro" class="btn btn-info btn-lg me-2">
                    <i class="fas fa-filter me-2"></i>Filtrar
                </a>
                <a href="/pasajes/exportar" class="btn btn-success btn-lg" title="Descargar lista en CSV">
                    <i class="fas fa-download me-2"></i>Descargar CSV
                </a>
            </div>
        </div>

        <% if (pasajes.length === 0) { %>
            <div class="table-card">
                <div class="empty-state">
                    <i class="fas fa-info-circle"></i>
                    <h3>No hay pasajes registrados</h3>
                    <p class="text-muted">Crea tu primer pasaje haciendo clic en "Nuevo Pasaje"</p>
                </div>
            </div>
        <% } else { %>
            <div class="table-card">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th><i class="fas fa-hashtag me-2"></i>ID</th>
                                <th><i class="fas fa-map-marker-alt me-2"></i>Ruta</th>
                                <th><i class="fas fa-license-plate me-2"></i>Placa</th>
                                <th><i class="fas fa-ticket-alt me-2"></i>Tipo</th>
                                <th><i class="fas fa-dollar-sign me-2"></i>Valor</th>
                                <th><i class="fas fa-calendar me-2"></i>Fecha y Hora</th>
                                <th><i class="fas fa-cogs me-2"></i>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% pasajes.forEach(pasaje => { %>
                                <tr>
                                    <td><span class="badge bg-info"><%= pasaje.ID_PASAJE %></span></td>
                                    <td><strong><%= pasaje.NOMBRE_RUTA %></strong></td>
                                    <td><%= pasaje.PLACA %></td>
                                    <td><span class="badge bg-warning text-dark"><%= pasaje.DESCRIPCION %></span></td>
                                    <td><span class="badge bg-success">$<%= pasaje.VALOR_FINAL %></span></td>
                                    <td><small><%= new Date(pasaje.FECHA_HORA).toLocaleString('es-ES') %></small></td>
                                    <td>
                                        <a href="/pasajes/editar/<%= pasaje.ID_PASAJE %>" class="btn btn-sm btn-edit">
                                            <i class="fas fa-edit me-1"></i>Editar
                                        </a>
                                        <a href="/pasajes/eliminar/<%= pasaje.ID_PASAJE %>" class="btn btn-sm btn-delete" onclick="return confirm('¿Estás seguro?')">
                                            <i class="fas fa-trash me-1"></i>Eliminar
                                        </a>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% } %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

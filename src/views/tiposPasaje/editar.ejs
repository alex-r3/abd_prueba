<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Tipo de Pasaje</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/styles.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid px-4">
            <a class="navbar-brand" href="/"><i class="fas fa-bus me-2"></i>Sistema de Pasajes</a>
        </div>
    </nav>

    <div class="container mt-5 mb-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="form-card">
                    <h1><i class="fas fa-edit me-3"></i>Editar Tipo de Pasaje</h1>
                    
                    <form action="/tipos-pasaje/actualizar/<%= tipo.ID_TIPO %>" method="POST">
                        <div class="form-group">
                            <label for="descripcion" class="form-label"><i class="fas fa-info-circle me-2"></i>Descripción</label>
                            <input type="text" class="form-control" id="descripcion" name="descripcion" value="<%= tipo.DESCRIPCION %>" required>
                        </div>
                        
                        <div class="form-group">
                            <label for="precio_base" class="form-label"><i class="fas fa-dollar-sign me-2"></i>Precio Base</label>
                            <input type="number" class="form-control" id="precio_base" name="precio_base" step="0.01" min="0" value="<%= tipo.PRECIO_BASE %>" required>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-save me-2"></i>Actualizar Tipo
                            </button>
                            <a href="/tipos-pasaje" class="btn btn-secondary btn-lg">
                                <i class="fas fa-times me-2"></i>Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tipos de Pasaje</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/styles.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid px-4">
            <a class="navbar-brand" href="/"><i class="fas fa-bus me-2"></i>Sistema de Pasajes</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/rutas"><i class="fas fa-map-marker-alt me-1"></i>Rutas</a></li>
                    <li class="nav-item"><a class="nav-link" href="/unidades"><i class="fas fa-truck me-1"></i>Unidades</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/tipos-pasaje"><i class="fas fa-ticket-alt me-1"></i>Tipos</a></li>
                    <li class="nav-item"><a class="nav-link" href="/pasajes"><i class="fas fa-receipt me-1"></i>Pasajes</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-5 mb-5">
        <div class="page-header d-flex justify-content-between align-items-center">
            <div>
                <h1><i class="fas fa-ticket-alt me-3"></i>Gestión de Tipos de Pasaje</h1>
            </div>
            <a href="/tipos-pasaje/crear" class="btn btn-primary btn-lg">
                <i class="fas fa-plus me-2"></i>Nuevo Tipo
            </a>
        </div>

        <% if (tipos.length === 0) { %>
            <div class="table-card">
                <div class="empty-state">
                    <i class="fas fa-info-circle"></i>
                    <h3>No hay tipos de pasaje registrados</h3>
                    <p class="text-muted">Crea tu primer tipo de pasaje haciendo clic en "Nuevo Tipo"</p>
                </div>
            </div>
        <% } else { %>
            <div class="table-card">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th><i class="fas fa-hashtag me-2"></i>ID</th>
                                <th><i class="fas fa-info-circle me-2"></i>Descripción</th>
                                <th><i class="fas fa-dollar-sign me-2"></i>Precio Base</th>
                                <th><i class="fas fa-cogs me-2"></i>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% tipos.forEach(tipo => { %>
                                <tr>
                                    <td><span class="badge bg-info"><%= tipo.ID_TIPO %></span></td>
                                    <td><strong><%= tipo.DESCRIPCION %></strong></td>
                                    <td><span class="badge bg-success">$<%= tipo.PRECIO_BASE %></span></td>
                                    <td>
                                        <a href="/tipos-pasaje/editar/<%= tipo.ID_TIPO %>" class="btn btn-sm btn-edit">
                                            <i class="fas fa-edit me-1"></i>Editar
                                        </a>
                                        <a href="/tipos-pasaje/eliminar/<%= tipo.ID_TIPO %>" class="btn btn-sm btn-delete" onclick="return confirm('¿Estás seguro?')">
                                            <i class="fas fa-trash me-1"></i>Eliminar
                                        </a>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% } %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
